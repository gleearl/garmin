# Optional: pre-fill credentials so `login` doesn't prompt.
# You can leave these blank and type them at the prompt instead.
# This file is a template -- copy to `.env` (which is gitignored).
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Override the token store / DB locations if you like.
# GARMINTOKENS=~/.garminconnect
# GARMIN_DB=./garmin.db

# --- MCP connector (garmin_dash.mcp_server) ---
# Lets Claude read your data via the Laravel backend. See MCP.md.
GARMIN_API_URL=https://backend.gleearl.com
# Sanctum read token: php artisan garmin:token --read  (keep private)
GARMIN_READ_TOKEN=
